# ─────────────────────────────────────────────────────────────────────────────
# mail.sharexpress.in — Environment Configuration
# Copy to .env and fill in your values before running docker compose up
# ─────────────────────────────────────────────────────────────────────────────

# ─── Project ──────────────────────────────────────────────────────────────────
PROJECT_ENV=production
MAIL_DOMAIN=sharexpress.in
MAIL_HOSTNAME=mail.sharexpress.in

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-256-bit-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=maildb

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://mail:mailpassword@rabbitmq:5672/
RABBITMQ_PASSWORD=mailpassword

# ─── Postfix / Dovecot ────────────────────────────────────────────────────────
POSTFIX_HOST=postfix
POSTFIX_PORT=25
DOVECOT_HOST=dovecot
DOVECOT_IMAP_PORT=143
DOVECOT_IMAPS_PORT=993

# ─── Mail Storage ─────────────────────────────────────────────────────────────
# Base path for Maildir storage (inside container)
MAIL_VHOST_PATH=/var/mail/vhosts

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=santusht@sharexpress.in
ADMIN_PASSWORD=change-this-immediately

# ─── Frontend URL ─────────────────────────────────────────────────────────────
FRONTEND_URL=https://mail.sharexpress.in
BACKEND_URL=https://api.mail.sharexpress.in
CORS_ORIGINS=https://mail.sharexpress.in,http://localhost:5173

# ─── Attachments ──────────────────────────────────────────────────────────────
ATTACHMENT_DIR=/app/attachments
MAX_ATTACHMENT_SIZE_MB=25

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
SMTP_RATE_LIMIT_PER_HOUR=500

# ─── SSL (Let's Encrypt paths inside containers) ──────────────────────────────
SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem
